{
  "name": "backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run build && bun run --hot src/index.tsx",
    "build:css": "tailwindcss -i src/style.css -o src/public/style.css",
    "build:js": "bun build src/frontend.ts --outdir src/public --minify",
    "build": "bun run build:css && bun run build:js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/bun": "^1.3.13",
    "tailwindcss": "^4.3.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "alpinejs": "^3.15.12",
    "fengari": "^0.1.5",
    "hono": "^4.12.18",
    "htmx.org": "^2.0.10"
  }
}
